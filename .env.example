# =============================================================================
# Bazar Moderno - Variables de entorno
#
# Copiá este archivo como `.env` y completá los valores. NO commitees `.env`.
# En producción (Render), seteá estas mismas variables en el dashboard del
# servicio: Settings -> Environment.
# =============================================================================

# --- Server ---
PORT=3000
CORS_ORIGIN=*

# --- Auth ---
# CAMBIAR este valor por algo random largo en producción.
# Sugerencia: generar con `openssl rand -hex 64`
JWT_SECRET=cambiame-en-produccion-por-algo-random
JWT_EXPIRES_IN=7d

# --- Database ---
# Path al archivo SQLite. En Render apuntá a un disco persistente, ej:
#   DB_PATH=/var/data/bazar.db
DB_PATH=./src/db/bazar.db

# --- Uploads (límites y procesamiento de imágenes) ---
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
IMAGE_MAX_WIDTH=1600
IMAGE_QUALITY=80
THUMB_WIDTH=400

# --- Storage local (default si NO seteás R2) ---
# Carpeta donde se guardan los archivos subidos.
# En Render con disco persistente, apuntá al disco montado, ej:
#   UPLOADS_DIR=/var/data/uploads
UPLOADS_DIR=./uploads
# Si usás storage local y querés URLs absolutas en lugar de relativas
# (tipo https://tu-app.onrender.com/uploads/...), seteá:
# PUBLIC_BASE_URL=https://tu-app.onrender.com

# --- Cloudflare R2 (opcional) ---
# Si seteás las 4 vars R2_ACCOUNT_ID + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
# + R2_BUCKET, el server cambia automáticamente a R2 al arrancar.
# Si dejás cualquiera vacía, sigue usando disco local.
# R2_ACCOUNT_ID=tu-account-id-de-32-chars
# R2_ACCESS_KEY_ID=tu-access-key
# R2_SECRET_ACCESS_KEY=tu-secret-key
# R2_BUCKET=bazar-moderno
# R2_PUBLIC_URL=https://files.tudominio.com    # o https://pub-XXXX.r2.dev