{
  "name": "bazar-moderno-backend",
  "version": "1.0.0",
  "description": "API REST para Bazar Moderno - e-commerce de artículos para el hogar",
  "main": "src/server.js",
  "scripts": {
    "start": "node --no-warnings --experimental-sqlite src/server.js",
    "dev": "node --no-warnings --experimental-sqlite --watch src/server.js",
    "seed": "node --no-warnings --experimental-sqlite src/db/seed.js",
    "init-db": "node --no-warnings --experimental-sqlite src/db/init.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "ecommerce",
    "bazar",
    "express",
    "sqlite"
  ],
  "author": "Franco",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "tslib": "^2.8.1"
  }
}
